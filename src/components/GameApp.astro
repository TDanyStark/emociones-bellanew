---
import { URL_BASE } from "@/config";
---

<div id="game-root" class="select-none">
  <!-- Reset button -->
  <div class="flex justify-end mb-4">
    <button
      id="game-reset-btn"
      type="button"
      class="rounded-full border border-pink px-4 py-1.5 text-xs font-black uppercase tracking-wide text-[#d9609a] transition hover:bg-[#d9609a] hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#d9609a]"
    >
      Reiniciar
    </button>
  </div>

  <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start justify-between">

    <!-- Left: Emotion chips -->
    <div id="emotions-col" class="flex flex-col gap-3 w-full md:w-56 shrink-0">
      <div class="emotion-chip cursor-grab" data-emotion="happy" draggable="true">
        <div class="chip-inner flex items-center gap-3 px-5 py-3 rounded-2xl text-white font-bold text-xl transition-all duration-150">
          <img src={`${URL_BASE}/icons/icon_happy_1.webp`} class="w-10 h-10 shrink-0" alt="Alegría">
          <span>ALEGRÍA</span>
        </div>
      </div>

      <div class="emotion-chip cursor-grab" data-emotion="calm" draggable="true">
        <div class="chip-inner flex items-center gap-3 px-5 py-3 rounded-2xl text-white font-bold text-xl transition-all duration-150">
          <img src={`${URL_BASE}/icons/icon_calm_1.webp`} class="w-10 h-10 shrink-0" alt="Calma">
          <span>CALMA</span>
        </div>
      </div>

      <div class="emotion-chip cursor-grab" data-emotion="energy" draggable="true">
        <div class="chip-inner flex items-center gap-3 px-5 py-3 rounded-2xl text-white font-bold text-xl transition-all duration-150">
          <img src={`${URL_BASE}/icons/icon_energy_1.webp`} class="w-10 h-10 shrink-0" alt="Energía">
          <span>ENERGÍA</span>
        </div>
      </div>

      <div class="emotion-chip cursor-grab" data-emotion="optimism" draggable="true">
        <div class="chip-inner flex items-center gap-3 px-5 py-3 rounded-2xl text-white font-bold text-xl transition-all duration-150">
          <img src={`${URL_BASE}/icons/icon_optimism_1.webp`} class="w-10 h-10 shrink-0" alt="Optimismo">
          <span>OPTIMISMO</span>
        </div>
      </div>
    </div>

    <!-- Right: Song players (populated + shuffled by JS) -->
    <div id="songs-col" class="flex flex-col gap-3 flex-1 w-full max-w-96"></div>
  </div>
</div>

<!-- Success Popup -->
<div id="success-overlay" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.55)">
  <div class="relative max-w-xl w-full">
    <button id="success-close"
      class="absolute -top-4 -right-4 z-10 w-10 h-10 rounded-full text-white font-bold text-lg flex items-center justify-center cursor-pointer shadow-lg"
      style="background:#d9609a">✕</button>
    <div id="success-box" class="rounded-3xl p-8 w-full max-h-[90vh] overflow-y-auto shadow-2xl">
      <div id="success-body"></div>
    </div>
  </div>
</div>

<!-- Fail Popup -->
<div id="fail-overlay" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.55)">
  <div class="relative max-w-sm w-full">
    <button id="fail-close"
      class="absolute -top-4 -right-4 z-10 w-10 h-10 rounded-full text-white font-bold text-lg flex items-center justify-center cursor-pointer shadow-lg"
      style="background:#d9609a">✕</button>
    <div class="bg-white rounded-3xl p-10 text-center w-full shadow-2xl">
      <div class="text-5xl mb-4">🎵</div>
      <p class="text-2xl font-bold mb-2" style="color:#772583">¡Intenta de nuevo!</p>
      <p class="text-gray-500 mb-6 text-sm">Escucha bien las canciones e intenta de nuevo.</p>
    </div>
  </div>
</div>

<!-- Win Popup -->
<div id="win-overlay" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.55)">
  <div class="relative max-w-sm w-full">
    <div class="rounded-3xl p-8 text-center w-full shadow-2xl text-white" style="background:linear-gradient(135deg,#772583,#d9609a)">
      <div class="text-5xl mb-4">🎉</div>
      <h2 class="text-3xl font-black leading-none mb-3">¡Lo lograste!</h2>
      <p id="win-attempts-text" class="text-lg font-semibold mb-6 opacity-90"></p>
      <div id="win-perfect-badge" class="mb-5 rounded-full px-4 py-1.5 text-sm font-black uppercase tracking-wide" style="background:rgba(255,255,255,0.25);display:none">
        ¡Puntaje perfecto! 🏆
      </div>
      <div class="flex flex-col gap-3">
        <button
          id="win-restart"
          type="button"
          class="rounded-full px-8 py-3 text-base font-black uppercase text-[#772583] shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl"
          style="background:#ffffff"
        >
          Jugar de nuevo
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import confetti from "canvas-confetti";
  window.quizConfetti = confetti;
</script>

<script define:vars={{ URL_BASE }}>
// ─── DATA ────────────────────────────────────────────────────────────────────
const EMOTIONS = {
  happy:    { label: 'ALEGRÍA',   icon: `${URL_BASE}/icons/icon_happy_1.webp`,    sound: `${URL_BASE}/sounds/happy.mp3`    },
  calm:     { label: 'CALMA',     icon: `${URL_BASE}/icons/icon_calm_1.webp`,     sound: `${URL_BASE}/sounds/calm.mp3`     },
  energy:   { label: 'ENERGÍA',   icon: `${URL_BASE}/icons/icon_energy_1.webp`,   sound: `${URL_BASE}/sounds/energy.mp3`   },
  optimism: { label: 'OPTIMISMO', icon: `${URL_BASE}/icons/icon_optimism_1.webp`, sound: `${URL_BASE}/sounds/optimism.mp3` },
};

const POPUP_CONTENT = {
  happy: {
    bg: '#772583',
    html: `
      <div class="flex items-start gap-4 mb-5">
        <img src="${URL_BASE}/icons/icon_happy_1.webp" class="w-14 h-14 shrink-0" alt="">
        <h2 style="color:#fff;font-size:1.3rem;font-weight:700;line-height:1.3">
          BENEFICIOS EN LA <span style="color:#d787b5">QUÍMICA CEREBRAL:</span><br>SEROTONINA Y ENDORFINAS
        </h2>
      </div>
      <p style="color:#fff;font-weight:700;margin-bottom:1rem">
        El estrógeno actúa directamente en las partes del cerebro que controlan las emociones. Entre sus efectos positivos se encuentran:<sup>1</sup>
      </p>
      <div style="display:flex;flex-direction:column;gap:0.75rem">
        <div style="display:flex;align-items:flex-start;gap:1rem;background:rgba(255,255,255,0.15);border-radius:9999px;padding:0.6rem 1rem">
          <img src="${URL_BASE}/icons/icon_happy_1.webp" style="width:2rem;height:2rem;flex-shrink:0" alt="">
          <p style="color:#fff;font-size:0.875rem;margin:0">Aumenta la serotonina y sus receptores en el cerebro, lo cual es clave para mantener un buen estado de ánimo.<sup>1</sup></p>
        </div>
        <div style="display:flex;align-items:flex-start;gap:1rem;background:rgba(255,255,255,0.15);border-radius:9999px;padding:0.6rem 1rem">
          <img src="${URL_BASE}/icons/icon_happy_1.webp" style="width:2rem;height:2rem;flex-shrink:0" alt="">
          <p style="color:#fff;font-size:0.875rem;margin:0">Influye en la producción de endorfinas, las sustancias químicas del cerebro que producen sensaciones de bienestar.<sup>1</sup></p>
        </div>
        <div style="display:flex;align-items:flex-start;gap:1rem;background:rgba(255,255,255,0.15);border-radius:9999px;padding:0.6rem 1rem">
          <img src="${URL_BASE}/icons/icon_happy_1.webp" style="width:2rem;height:2rem;flex-shrink:0" alt="">
          <p style="color:#fff;font-size:0.875rem;margin:0">Ejerce un efecto neuroprotector.<sup>1</sup></p>
        </div>
      </div>
      <p style="color:rgba(255,255,255,0.65);font-size:0.7rem;margin-top:1.5rem">
        <strong>Referencia 1.</strong> Hoffman M, Powell A. The Effects of Estrogen on Women's Emotions and Mood. WebMD; 2024. Disponible en: https://n9.cl/09ner
      </p>`
  },
  calm: {
    bg: '#d9609a',
    html: `
      <div class="flex items-start gap-4 mb-5">
        <img src="${URL_BASE}/icons/icon_calm_1.webp" class="w-14 h-14 shrink-0" alt="">
        <h2 style="color:#fff;font-size:1.3rem;font-weight:700;line-height:1.3">
          ESTABILIZACIÓN DE LAS <strong>FLUCTUACIONES HORMONALES</strong>
        </h2>
      </div>
      <p style="color:#fff;margin-bottom:0.75rem">
        <strong>En el ciclo menstrual normal, los niveles de estrógenos sufren picos repentinos (antes de la ovulación) y caídas drásticas (antes de la menstruación). Estas fluctuaciones son las que suelen desencadenar cambios en los estados de ánimo, como irritabilidad y ansiedad.</strong>
        Al administrar una dosis constante de estrógeno natural a través de un anticonceptivo, se mantiene un nivel hormonal estable, evitando los periodos de &ldquo;abstinencia&rdquo; de estrógenos que pueden dejar a la persona más vulnerable a presentar dificultades para controlar sus emociones.<sup>1-3</sup>
      </p>
      <p style="color:rgba(255,255,255,0.65);font-size:0.7rem;margin-top:1.5rem">
        <strong>Referencia 1.</strong> Denninger A, Rehbein E, Sundström-Poromaa I, et al. Estradiol, Emotion Regulation, and the Limbic System: Effects on Gray Matter Volume. Biological Psychiatry: Global Open Science. 2026;6:100709.
        <strong>2.</strong> Hoffman M, Powell A. The Effects of Estrogen on Women's Emotions and Mood. WebMD; 2024. Disponible en: https://n9.cl/09ner
        <strong>3.</strong> Homewood Health. Exploring the Connection Between Women's Hormonal Imbalances and Mental Health. 2024. Disponible en: https://n9.cl/bn1z3
      </p>`
  },
  energy: {
    bg: '#753bbd',
    html: `
      <div class="flex items-start gap-4 mb-5">
        <img src="${URL_BASE}/icons/icon_energy_1.webp" class="w-14 h-14 shrink-0" alt="">
        <h2 style="color:#fff;font-size:1.3rem;font-weight:700;line-height:1.3">
          IMPACTO POSITIVO EN LA <strong>ESTRUCTURA</strong> <span style="color:#d787b5">CEREBRAL</span>
        </h2>
      </div>
      <p style="color:#fff;margin-bottom:0.75rem">
        <strong>El estrógeno influye en la plasticidad de regiones como el cuerpo estriado, que está involucrado en el procesamiento de recompensas, el estrés y la regulación emocional.</strong>
        Los estudios sugieren que mantener niveles estables de estrógeno puede ayudar a fomentar un refinamiento estructural en estos circuitos afectivos clave, lo que podría representar una respuesta neuroplástica beneficiosa para la salud mental durante períodos de sensibilidad hormonal.<sup>1</sup>
      </p>
      <p style="color:rgba(255,255,255,0.65);font-size:0.7rem;margin-top:1.5rem">
        <strong>Referencia 1.</strong> Denninger A, Rehbein E, Sundström-Poromaa I, et al. Estradiol, Emotion Regulation, and the Limbic System: Effects on Gray Matter Volume. Biological Psychiatry: Global Open Science. 2026;6:100709.
      </p>`
  },
  optimism: {
    bg: '#772583',
    html: `
      <div class="flex items-start gap-4 mb-5">
        <img src="${URL_BASE}/icons/icon_optimism_1.webp" class="w-14 h-14 shrink-0" alt="">
        <h2 style="color:#fff;font-size:1.3rem;font-weight:700;line-height:1.3">
          REGULACIÓN <span style="color:#d787b5">EMOCIONAL</span>
        </h2>
      </div>
      <p style="color:#fff;font-weight:700;margin-bottom:1rem">
        La evidencia indica que la capacidad de una persona para controlar sus emociones está mediada por los niveles de estrógeno.<sup>1</sup>
      </p>
      <div style="display:flex;flex-direction:column;gap:0.75rem">
        <div style="display:flex;align-items:flex-start;gap:1rem;background:rgba(255,255,255,0.15);border-radius:9999px;padding:0.6rem 1rem">
          <img src="${URL_BASE}/icons/icon_optimism_1.webp" style="width:2rem;height:2rem;flex-shrink:0" alt="">
          <p style="color:#fff;font-size:0.875rem;margin:0">Los niveles estables altos de estrógeno están asociados con un uso más efectivo de la reevaluación cognitiva, que consiste en cambiar el significado de una situación negativa para reducir su impacto emocional.<sup>1</sup></p>
        </div>
        <div style="display:flex;align-items:flex-start;gap:1rem;background:rgba(255,255,255,0.15);border-radius:9999px;padding:0.6rem 1rem">
          <img src="${URL_BASE}/icons/icon_optimism_1.webp" style="width:2rem;height:2rem;flex-shrink:0" alt="">
          <p style="color:#fff;font-size:0.875rem;margin:0">Cuando el estrógeno está bajo, las personas suelen tener menos éxito al intentar regular sus emociones y pueden experimentar un afecto negativo mayor si tienden a enfocarse repetitivamente en pensamientos negativos (rumiación), pero, al tener niveles estables, se previene esta conducta.<sup>1</sup></p>
        </div>
      </div>
      <p style="color:rgba(255,255,255,0.65);font-size:0.7rem;margin-top:1.5rem">
        <strong>Referencia 1.</strong> Denninger A, Rehbein E, Sundström-Poromaa I, et al. Estradiol, Emotion Regulation, and the Limbic System: Effects on Gray Matter Volume. Biological Psychiatry: Global Open Science. 2026;6:100709.
      </p>`
  }
};

// ─── BRAND COLORS ─────────────────────────────────────────────────────────────
var CONFETTI_COLORS = ["#d9609a", "#772583", "#ffffff"];

// ─── STATE ───────────────────────────────────────────────────────────────────
let currentAudio = null;
let currentPlayingId = null;
let selectedEmotion = null;
const matched = {};
let wrongAttempts = 0;
let confettiTimer = null;
let pendingWin = false;

// ─── AUDIO ───────────────────────────────────────────────────────────────────
function stopCurrentAudio() {
  if (!currentAudio) return;
  currentAudio.pause();
  currentAudio.currentTime = 0;
  if (currentPlayingId) {
    const card = document.querySelector(`.song-card[data-song="${currentPlayingId}"]`);
    if (card) setPlayerState(card, false);
  }
  currentAudio = null;
  currentPlayingId = null;
}

function playAudio(src, songId, card) {
  if (currentPlayingId === songId) { stopCurrentAudio(); return; }
  stopCurrentAudio();
  const audio = new Audio(src);
  currentAudio = audio;
  currentPlayingId = songId;
  setPlayerState(card, true);
  audio.play().catch(() => {});

  audio.addEventListener('timeupdate', () => {
    const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
    const bar = card.querySelector('.time-bar');
    if (bar) bar.style.width = pct + '%';
  });

  audio.addEventListener('ended', () => {
    setPlayerState(card, false);
    const bar = card.querySelector('.time-bar');
    if (bar) bar.style.width = '0%';
    currentAudio = null;
    currentPlayingId = null;
  });
}

function setPlayerState(card, playing) {
  const waveform = card.querySelector('.waveform');
  const btn = card.querySelector('.play-btn');
  if (waveform) waveform.classList.toggle('playing', playing);
  if (btn) {
    btn.innerHTML = playing
      ? `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>`
      : `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M8 5v14l11-7z"/></svg>`;
  }
}

// ─── WAVEFORM GENERATION ─────────────────────────────────────────────────────
function generateBars(count = 20) {
  let html = '';
  for (let i = 0; i < count; i++) {
    // Bell-curve envelope: taller in the middle, shorter at edges
    const center = (count - 1) / 2;
    const base = 22 + 58 * Math.exp(-0.28 * Math.pow((i - center) / (count / 4.5), 2));
    const noise = (Math.random() - 0.5) * 24;
    const maxH = Math.max(10, Math.min(96, base + noise));
    const minH = Math.max(4, maxH * (0.08 + Math.random() * 0.12));
    // Vary animation duration slightly per bar for more organic feel
    const dur = (0.5 + Math.random() * 0.35).toFixed(3);
    const delay = (i * 0.055).toFixed(3);
    html += `<div class="wave-bar" style="height:${maxH.toFixed(1)}%;--min-h:${minH.toFixed(1)}%;--max-h:${maxH.toFixed(1)}%;--dur:${dur}s;animation-delay:${delay}s"></div>`;
  }
  return html;
}

// ─── SONG CARD CREATION ───────────────────────────────────────────────────────
function createSongCard(songId) {
  const div = document.createElement('div');
  div.className = 'song-card';
  div.dataset.song = songId;
  div.style.cursor = 'pointer';

  div.innerHTML = `
    <div class="player-row">
      <img src="${URL_BASE}/icons/icon_music_1.webp" class="music-icon" alt="">

      <div class="player-body">
        <div class="waveform">${generateBars()}</div>
        <div class="progress-track">
          <div class="time-bar"></div>
        </div>
      </div>

      <div class="play-btn" aria-label="Play/Pause" role="img">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M8 5v14l11-7z"/></svg>
      </div>
    </div>

    <div class="drop-hint">Arrastra o toca la emoción aquí ↑</div>
    <div class="matched-display" style="display:none"></div>
  `;

  // ── Drag-and-drop target events ──
  let dropJustHappened = false;

  div.addEventListener('dragover', (e) => {
    if (matched[songId]) return;
    e.preventDefault();
    div.classList.add('drag-over');
  });
  div.addEventListener('dragleave', () => div.classList.remove('drag-over'));
  div.addEventListener('drop', (e) => {
    e.preventDefault();
    div.classList.remove('drag-over');
    if (matched[songId]) return;
    const emotionId = e.dataTransfer.getData('emotion');
    if (emotionId) {
      dropJustHappened = true;
      setTimeout(() => { dropJustHappened = false; }, 300);
      handleDrop(songId, emotionId, div);
    }
  });

  // ── Unified click: drop emotion if selected, otherwise play/pause ──
  div.addEventListener('click', () => {
    if (dropJustHappened) return;
    if (!matched[songId] && selectedEmotion) {
      handleDrop(songId, selectedEmotion, div);
      return;
    }
    const em = EMOTIONS[songId];
    playAudio(em.sound, songId, div);
  });

  return div;
}

// ─── GAME LOGIC ───────────────────────────────────────────────────────────────
function handleDrop(songId, emotionId, songCard) {
  if (!emotionId || matched[songId]) return;

  if (songId === emotionId) {
    // ✅ Correct
    matched[songId] = emotionId;
    stopCurrentAudio();

    const em = EMOTIONS[emotionId];
    const sound = new Audio(`${URL_BASE}/sounds/confetti.mp3`);
    sound.play().catch(() => {});

    launchSideConfetti();

    songCard.classList.add('matched');
    const hint = songCard.querySelector('.drop-hint');
    if (hint) hint.style.display = 'none';

    const display = songCard.querySelector('.matched-display');
    display.innerHTML = `<img src="${em.icon}" alt=""><span>${em.label}</span>`;
    display.style.display = 'flex';

    // Disable the emotion chip
    const chip = document.querySelector(`.emotion-chip[data-emotion="${emotionId}"]`);
    if (chip) {
      chip.classList.add('used');
      chip.draggable = false;
    }

    clearSelectedEmotion();
    setTimeout(() => {
      showSuccessPopup(emotionId);
      checkWin();
    }, 450);

  } else {
    // ❌ Wrong
    wrongAttempts++;
    clearSelectedEmotion();
    stopCurrentAudio();
    const fail = new Audio(`${URL_BASE}/sounds/fail.mp3`);
    fail.play().catch(() => {});

    // Shake the song card
    songCard.classList.add('shake');
    setTimeout(() => songCard.classList.remove('shake'), 600);

    showFailPopup();
  }
}

function clearSelectedEmotion() {
  if (!selectedEmotion) return;
  const chip = document.querySelector(`.emotion-chip[data-emotion="${selectedEmotion}"]`);
  if (chip) chip.classList.remove('selected');
  selectedEmotion = null;
}

function showSuccessPopup(emotionId) {
  const data = POPUP_CONTENT[emotionId];
  const overlay = document.getElementById('success-overlay');
  const box = document.getElementById('success-box');
  const body = document.getElementById('success-body');
  box.style.backgroundColor = data.bg;
  body.innerHTML = data.html;
  overlay.classList.remove('hidden');
}

function showFailPopup() {
  document.getElementById('fail-overlay').classList.remove('hidden');
}

// ─── CONFETTI ─────────────────────────────────────────────────────────────────
function launchSideConfetti() {
  const confetti = window.quizConfetti;
  if (!confetti) return;
  confetti({ particleCount: 70, spread: 55, angle: 60,  origin: { x: 0, y: 0.55 }, colors: CONFETTI_COLORS });
  confetti({ particleCount: 70, spread: 55, angle: 120, origin: { x: 1, y: 0.55 }, colors: CONFETTI_COLORS });
}

function launchPerfectFinishConfetti() {
  const confetti = window.quizConfetti;
  if (!confetti) return;
  const end = Date.now() + 3000;
  clearInterval(confettiTimer);
  confettiTimer = setInterval(() => {
    confetti({
      particleCount: 55,
      spread: 360,
      startVelocity: 32,
      origin: { x: Math.random(), y: Math.random() * 0.55 },
      colors: CONFETTI_COLORS,
    });
    const burst = new Audio(`${URL_BASE}/sounds/confetti.mp3`);
    burst.volume = 0.5;
    burst.play().catch(() => {});
    if (Date.now() > end) clearInterval(confettiTimer);
  }, 250);
}

// ─── WIN / RESET ──────────────────────────────────────────────────────────────
function checkWin() {
  if (Object.keys(matched).length < 4) return;
  const isPerfect = wrongAttempts === 0;
  const attemptsText = isPerfect
    ? '¡Emparejaste todo a la primera!'
    : wrongAttempts === 1
      ? 'Tuviste 1 intento fallido'
      : `Tuviste ${wrongAttempts} intentos fallidos`;
  document.getElementById('win-attempts-text').textContent = attemptsText;
  const badge = document.getElementById('win-perfect-badge');
  badge.style.display = isPerfect ? 'inline-block' : 'none';
  // Don't show win popup yet — wait until the user closes the last success popup
  pendingWin = true;
}

function showWinPopup() {
  pendingWin = false;
  document.getElementById('win-overlay').classList.remove('hidden');
  document.getElementById('win-overlay').classList.add('flex');
  if (wrongAttempts === 0) launchPerfectFinishConfetti();
}

function resetGame() {
  clearInterval(confettiTimer);
  stopCurrentAudio();
  // Reset state
  Object.keys(matched).forEach(k => delete matched[k]);
  wrongAttempts = 0;
  selectedEmotion = null;
  pendingWin = false;
  // Hide popups
  document.getElementById('win-overlay').classList.add('hidden');
  document.getElementById('win-overlay').classList.remove('flex');
  document.getElementById('success-overlay').classList.add('hidden');
  document.getElementById('fail-overlay').classList.add('hidden');
  // Re-render songs col
  const songsCol = document.getElementById('songs-col');
  songsCol.innerHTML = '';
  const ids = ['happy', 'calm', 'energy', 'optimism'].sort(() => Math.random() - 0.5);
  ids.forEach(id => songsCol.appendChild(createSongCard(id)));
  // Re-enable chips
  document.querySelectorAll('.emotion-chip').forEach(chip => {
    chip.classList.remove('used', 'selected', 'dragging');
    chip.draggable = true;
  });
}

// ─── TOUCH DRAG ──────────────────────────────────────────────────────────────
let touchClone = null;
let touchEmotion = null;
let touchChipW = 0;

function initTouchDrag(chip, emotionId) {
  chip.addEventListener('touchstart', (e) => {
    if (chip.classList.contains('used')) return;
    const touch = e.touches[0];
    touchEmotion = emotionId;
    touchChipW = chip.offsetWidth;

    // Clone the inner chip visually
    const inner = chip.querySelector('.chip-inner');
    touchClone = inner.cloneNode(true);
    touchClone.style.cssText = `
      position:fixed;z-index:9999;pointer-events:none;opacity:0.88;
      width:${touchChipW}px;border-radius:1rem;
      left:${touch.clientX - touchChipW / 2}px;
      top:${touch.clientY - 30}px;
    `;
    document.body.appendChild(touchClone);
    e.preventDefault();
  }, { passive: false });

  chip.addEventListener('touchmove', (e) => {
    if (!touchClone) return;
    const touch = e.touches[0];
    touchClone.style.left = (touch.clientX - touchChipW / 2) + 'px';
    touchClone.style.top  = (touch.clientY - 30) + 'px';
    e.preventDefault();
  }, { passive: false });

  chip.addEventListener('touchend', (e) => {
    if (touchClone) { touchClone.remove(); touchClone = null; }
    const touch = e.changedTouches[0];
    const el = document.elementFromPoint(touch.clientX, touch.clientY);
    const card = el && el.closest('.song-card');
    if (card && touchEmotion) {
      handleDrop(card.dataset.song, touchEmotion, card);
    }
    touchEmotion = null;
    e.preventDefault();
  }, { passive: false });
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
function init() {
  const songsCol = document.getElementById('songs-col');

  // Shuffle and render song cards
  const ids = ['happy', 'calm', 'energy', 'optimism'].sort(() => Math.random() - 0.5);
  ids.forEach(id => songsCol.appendChild(createSongCard(id)));

  // Wire up emotion chips
  document.querySelectorAll('.emotion-chip').forEach(chip => {
    const emotionId = chip.dataset.emotion;

    // HTML5 drag
    chip.addEventListener('dragstart', (e) => {
      if (chip.classList.contains('used')) { e.preventDefault(); return; }
      e.dataTransfer.setData('emotion', emotionId);
      chip.classList.add('dragging');
    });
    chip.addEventListener('dragend', () => chip.classList.remove('dragging'));

    // Click-to-select
    chip.addEventListener('click', () => {
      if (chip.classList.contains('used')) return;
      if (selectedEmotion === emotionId) { clearSelectedEmotion(); return; }
      clearSelectedEmotion();
      selectedEmotion = emotionId;
      chip.classList.add('selected');
    });

    // Touch drag
    initTouchDrag(chip, emotionId);
  });

  // Close buttons
  function closeSuccessPopup() {
    document.getElementById('success-overlay').classList.add('hidden');
    if (pendingWin) showWinPopup();
  }
  document.getElementById('success-close').addEventListener('click', closeSuccessPopup);
  document.getElementById('success-overlay').addEventListener('click', (e) => {
    if (e.target === document.getElementById('success-overlay')) closeSuccessPopup();
  });

  document.getElementById('fail-close').addEventListener('click', () => {
    document.getElementById('fail-overlay').classList.add('hidden');
  });
  document.getElementById('fail-overlay').addEventListener('click', (e) => {
    if (e.target === document.getElementById('fail-overlay'))
      document.getElementById('fail-overlay').classList.add('hidden');
  });

  // Reset button
  document.getElementById('game-reset-btn').addEventListener('click', resetGame);

  // Win popup restart
  document.getElementById('win-restart').addEventListener('click', resetGame);
  document.getElementById('win-overlay').addEventListener('click', (e) => {
    if (e.target === document.getElementById('win-overlay')) resetGame();
  });
}

document.addEventListener('DOMContentLoaded', init);
</script>

